{
  "name": "buy-wise-backend",
  "scripts": {
    "dev": "bun run --hot index.ts",
    "build": "bun build index.ts --outdir dist",
    "start": "bun run index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "db:push": "bunx drizzle-kit push",
    "auth:generate": "bunx @better-auth/cli generate --output ./src/db/schemas/auth.ts --config ./src/lib/auth.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@orpc/client": "^1.9.3",
    "@orpc/openapi": "^1.9.3",
    "@orpc/server": "^1.9.3",
    "@orpc/zod": "^1.9.3",
    "better-auth": "^1.3.24",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "hono": "^4.9.9"
  },
  "devDependencies": {
    "@drzl/cli": "^0.3.1",
    "@types/bun": "latest",
    "@types/node": "^24.7.1",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  }
}
